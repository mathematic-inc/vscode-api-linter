{
  "name": "mathematic-vscode-api-linter",
  "displayName": "API Linter",
  "version": "1.2.3",
  "description": "Lint Protobuf API files using API Linter",
  "categories": [
    "Linters"
  ],
  "keywords": [
    "aip",
    "api-linter",
    "grpc",
    "linter",
    "proto3",
    "protobuf"
  ],
  "license": "Apache-2.0",
  "author": "Mathematic Inc",
  "repository": {
    "type": "git",
    "url": "https://github.com/mathematic-inc/vscode-api-linter.git"
  },
  "publisher": "mathematic",
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "build": "tsup",
    "watch": "tsup --watch",
    "package": "tsup --minify",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "prepare": "lefthook install",
    "deploy": "vsce publish",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.120.0",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^13.0.6",
    "lefthook": "^2.1.8",
    "mocha": "^11.7.6",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "ultracite": "^7.8.0",
    "vsce": "^2.15.0"
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "API Linter",
      "properties": {
        "apiLinter.command": {
          "type": "array",
          "default": [
            "api-linter"
          ],
          "description": "Command to run for API linter."
        },
        "apiLinter.configFile": {
          "type": "string",
          "default": ".apilinter.yml",
          "description": "Path to a config file for API linter. If the file does not exist, a config will not be used."
        },
        "apiLinter.protoPaths": {
          "type": "array",
          "default": [],
          "description": "Include paths to use for proto imports."
        }
      }
    },
    "commands": [
      {
        "command": "apiLinter.lint",
        "title": "API Linter: Lint the current file"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:proto",
    "onLanguage:proto3"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "packageManager": "pnpm@11.3.0"
}
